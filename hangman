    "# Hangman :\n",
    "\n",
    "class hangman:\n",
    "\n",
    "    def __init__(self):\n",
    "        \n",
    "        self.word = input( \"write your word:\" )\n",
    "        self.lives = 6\n",
    "        self.guesses = []\n",
    "\n",
    "    def display(self):\n",
    "\n",
    "        for letter in self.word:\n",
    "\n",
    "            if (letter in self.guesses):\n",
    "                print(letter, end =\" \")\n",
    "\n",
    "            else:\n",
    "                print(\"_\", end = \" \")\n",
    "                \n",
    "        print()\n",
    "\n",
    "    def guess(self):\n",
    "\n",
    "        a = input(\" Write  your guess: \")\n",
    "        \n",
    "        if a in self.guesses:\n",
    "             print(\" Already guessed \")\n",
    "            \n",
    "                  \n",
    "        else:\n",
    "            self.guesses.append(a)\n",
    "            \n",
    "            if a not in self.word:\n",
    "                self.lives -= 1\n",
    "                \n",
    "                print(\"Lives remaining:\", self.lives)\n",
    "               \n",
    "                \n",
    "               \n",
    "    def is_won(self):\n",
    "\n",
    "        for letter in self.word:\n",
    "\n",
    "            if letter not in self.guesses:\n",
    "                return False\n",
    "\n",
    "        return True\n",
    "\n",
    "        \n",
    "\n",
    "game = hangman()\n",
    "\n",
    "while game.lives > 0 and not game.is_won():\n",
    "    \n",
    "    game.display()\n",
    "    game.guess()\n",
    "    \n",
    "if game.is_won():\n",
    "     print(\" You Won, word: \", game.word)\n",
    "\n",
    "else:\n",
    "    print(\" You Lost! the word was:\", game.word)\n",
    "    \n",
    "    "
